{
  "name": "mini-claude-code",
  "version": "1.0.0",
  "description": "一个可作为 npm 库和 CLI 使用的 Mini Claude Code 风格智能体工具包",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "type": "module",
  "bin": {
    "mini-claude": "./dist/mini-claude.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./cli": {
      "types": "./dist/mini-claude.d.ts",
      "import": "./dist/mini-claude.js"
    },
    "./tools/*": {
      "types": "./dist/tools/*.d.ts",
      "import": "./dist/tools/*.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "rollup -c",
    "start": "rollup -c && node dist/mini-claude.js",
    "typecheck": "tsc --noEmit",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.30.2",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "dotenv": "^17.4.2",
    "gray-matter": "^4.0.3",
    "iconv-lite": "^0.7.2",
    "openai": "^6.45.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/node": "^26.1.0",
    "rollup": "^4.62.2",
    "tslib": "^2.8.1",
    "typescript": "^6.0.3"
  }
}
